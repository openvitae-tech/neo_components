<%# app/views/view_components/cards/_action_banner_component.html.erb %>
<div class="bg-white border border-line-colour-light border-solid flex gap-5 items-center justify-center p-8 relative rounded-[32px] w-full max-w-[1144px]">
  <div class="border border-line-colour-light border-solid h-[308px] relative rounded-xl shrink-0 w-[290px]">
    <%= image_tag image_path, class: "absolute inset-0 max-w-none object-cover pointer-events-none rounded-[20px] h-full w-full" %>
  </div>
  <div class="flex flex-1 flex-col gap-5 items-center relative">
    <div class="bg-primary-light-50 overflow-hidden relative rounded-[20px] shrink-0 h-[100px] w-[100px] flex items-center justify-center">
      <%= icon(icon_name, css: "h-10 w-10 text-primary") %>
    </div>
    <div class="flex flex-col gap-3 items-center justify-center text-center w-full">
      <p class="font-semibold leading-9 text-3xl text-primary">
        <%= title %>
      </p>
      <p class="font-normal leading-6 text-base text-letter-color whitespace-nowrap">
        <%= subtitle %>
      </p>
    </div>
    <%= link_to button_text, button_url, class: "bg-primary border border-primary border-solid flex gap-2 items-center justify-center px-6 py-3 rounded-lg text-white font-semibold leading-7 text-lg whitespace-nowrap" %>
  </div>
</div>
